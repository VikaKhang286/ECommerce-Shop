<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>@ViewData["Title"]</title>
  <!-- favicon -->
  <link rel="shortcut icon" href="/images/logo/favicon.ico" type="image/x-icon">
  <!-- custom css link -->
  <link rel="stylesheet" href="/css/bootstrap.min.css">
  <!-- google font link -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>

<body>
  
  <header>
    <nav class="navbar navbar-expand-lg bg-body-tertiary">
        <div class="container-fluid">
            <a class="navbar-brand" href="#">EShop Dashboard</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" 
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarSupportedContent">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link active" aria-current="page" href="/dashboard">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" aria-current="page" href="/dashboard/role">Role</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard/product">Product</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Main
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/">Home</a></li>
                            <li><a class="dropdown-item" href="/cart">Cart</a></li>
                        </ul>
                    </li>
                </ul>
                <div class="d-flex gap-2 align-items-center">
                    <p class="text-primary mb-0">Hello, @User.Identity?.Name</p>
                    <a class="btn btn-danger" href="/auth/logout">Logout</a> 
                </div>
            </div>
        </div>
    </nav>
  </header>

  <main class="container-fluid">
    @RenderBody()
  </main>
  <footer>

  </footer>
  <script src="/js/bootstrap.bundle.min.js"></script>
  <script src="/js/jquery-4.0.0.min.js"></script>
  <!-- custom js link -->
  @* <script src="/js/script.js"></script> *@
  <!-- ionicon link -->
  <script type="module" src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.esm.js"></script>
  <script nomodule src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js"></script>
  
  @RenderSection("Scripts", required: false)
</body>

</html>