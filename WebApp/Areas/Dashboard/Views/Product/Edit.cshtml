@model Product
@{
    ViewData["Title"] = "Edit Product - Admin Page - eCommerce Shop";
}
<h1>Edit Product</h1>
<div class="row">
    <form method="post" enctype="multipart/form-data" class="col-4">
        <input type="hidden" asp-for="ProductId">
        <input type="hidden" asp-for="BrandId">
        <div class="mb-3">
            <label>Brand</label>
            <input class="form-control" value="@Model.BrandName" disabled>
        </div>
        <div class="mb-3">
            <label>Title</label>
            <input asp-for="Title" class="form-control">
        </div>
        <div class="mb-3">
            <label>Price</label>
            <input asp-for="Price" class="form-control">
        </div>
        <div class="mb-3">
            <label>SaleOff</label>
            <input asp-for="SaleOff" class="form-control">
        </div>
        <div class="mb-3">
            <label>Current Image</label><br>
            <input type="hidden" asp-for="ImageUrl">
            <img src="/images/products/@Model.ImageUrl" width="120" class="mb-2">
            <input type="file" name="imageFile" class="form-control" accept=".jpg,.jpeg,.png,.webp,.gif">
            @if(ViewBag.Message != null){
                <div class="alert alert-danger">@ViewBag.Message</div>
            }
        </div>
        <button class="btn btn-warning">Update</button>
        <a href="/dashboard/product" class="btn btn-secondary">Cancel</a>
    </form>
</div>