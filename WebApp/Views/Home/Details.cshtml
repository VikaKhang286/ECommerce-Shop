@model Product

@{
    ViewData["Title"] = Model.Title + " - eCommerce Shop";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-5">
            <img src="/images/products/@Model.ImageUrl" class="img-fluid rounded shadow" alt="@Model.Title">
        </div>
        <div class="col-md-7">
            <h1 class="mb-3">
                @Model.Title
            </h1>
            <h4 class="text-secondary mb-3">Brand: @Model.BrandName
            </h4>
            <div class="mb-3">
                <span class="fs-2 text-danger fw-bold">$@Model.SaleOff</span>
                <del class="fs-5 text-muted ms-2">$@Model.Price</del>
            </div>
            <div class="mb-4">
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p class="text-muted">@Model.Description</p>
                }
                else
                {
                    <p class="text-muted"> No description available.</p>
                }
            </div>
            <div class="d-flex gap-3">
                <form action="/cart/save" class="formCart" method="post">
                    <input type="hidden" name="productId" value="@Model.ProductId">
                    <input type="number" name="quantity" value="1" min="1" class="form-control w-25 mb-3">
                    <button class="btn btn-dark">Add To Cart</button>
                </form>
            </div>
        </div>
    </div>
    <a href="/" class="mt-3 btn btn-outline-secondary btn-lg">Back</a>
</div>
@section Scripts {
<script>
$('.formCart').submit(function(ev) {
  ev.preventDefault();
  let pid = $(this).find('[name=productId]').val();
  let qty = $(this).find('[name=quantity]').val();
  $.post('/cart/save', { productId: pid, quantity: qty },
    function() {   
      window.location.href = "/cart";
    }
  );
});
</script>
}